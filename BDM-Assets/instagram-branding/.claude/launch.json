{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-preview",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path'),m={'html':'text/html','css':'text/css','js':'application/javascript','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml'};h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':decodeURIComponent(q.url);let fp=p.join(process.cwd(),u);if(!f.existsSync(fp)){if(f.existsSync(fp.replace(/$/,''))){fp+='/'}else{r.writeHead(404);r.end('Not found');return}}if(f.statSync(fp).isDirectory()){let idx=p.join(fp,'index.html');if(f.existsSync(idx)){fp=idx}else{let files=f.readdirSync(fp);r.writeHead(200,{'Content-Type':'text/html'});r.end('<html><body><h2>'+u+'</h2><ul>'+files.map(f=>'<li><a href=\"'+p.join(u,f)+'\">'+f+'</a></li>').join('')+'</ul></body></html>');return}}let ext=p.extname(fp).slice(1);r.writeHead(200,{'Content-Type':m[ext]||'application/octet-stream'});f.createReadStream(fp).pipe(r)}).listen(3000,()=>console.log('Serving on http://localhost:3000'))"],
      "port": 3000
    }
  ]
}